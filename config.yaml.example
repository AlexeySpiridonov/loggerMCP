# Access key for transport authentication.
# Supported locations:
# - Authorization: Bearer <access_key>
# - X-Access-Key: <access_key>
# - ?access_key=<access_key> on the SSE URL
# The read_logs tool can also accept access_key as a legacy fallback.
access_key: "your-secret-key-here"

# Path to syslog file
syslog_path: "/var/log/syslog"

# Server port (default: 7777)
port: 7777

# TLS encryption (true = HTTPS with auto-generated certificate)
tls: true

# Certificate and key paths (auto-generated if not found)
# cert_file: "cert.pem"
# key_file: "key.pem"

# Response encryption key (AES-256-GCM). Client and server must share the same key.
# When set, client can pass encrypt: true to receive an encrypted response.
encryption_key: "my-secret-encryption-key"

# Public base URL used in manifest and health responses.
# Set this when the server is behind a reverse proxy or public hostname.
public_base_url: "https://logger.example.com"

# Manifest metadata and endpoints.
manifest_name: "logger.local/mcp"
manifest_title: "loggerMCP"
manifest_description: "Remote MCP server for Ubuntu syslog search workflows."
manifest_version: "1.0.0"
manifest_path: "/manifest"
manifest_remote_type: "sse"
# manifest_remote_url: "https://logger.example.com/sse"

# Health endpoint path.
health_path: "/health"
