# Access key for transport authentication.
# Supported locations:
# - Authorization: Bearer <access_key>
# - X-Access-Key: <access_key>
# - ?access_key=<access_key> on the SSE URL
# The read_logs tool can also accept access_key as a legacy fallback.
access_key: "set-a-secret-access-key"

# Path to the syslog file to read.
syslog_path: "/var/log/syslog"

# HTTP listen port.
port: 7777

# Enable HTTPS.
# When true, the server auto-generates a self-signed certificate if cert_file/key_file do not exist.
tls: true

# Certificate and key paths.
# Relative paths are resolved from the current working directory.
# In the packaged systemd service, the working directory is /var/lib/loggermcp.
# cert_file: "cert.pem"
# key_file: "key.pem"

# Optional response encryption key for read_logs encrypt=true.
# Leave empty to disable response encryption.
encryption_key: ""

# Optional public base URL used in manifest responses.
# Packaged installs set this to the server IP. Override it behind a reverse proxy or public hostname.
# public_base_url: "https://logger.example.com:7777"

# Manifest metadata and endpoints.
# Packaged installs replace manifest_name and manifest_title with the server hostname.
# The default logger.local/mcp value is also replaced with logger.<hostname>/mcp at startup.
manifest_name: "logger.local/mcp"
manifest_title: "loggerMCP"
manifest_description: "Remote MCP server for Ubuntu syslog search workflows."
manifest_version: "1.0.0"
manifest_path: "/.well-known/mcp-manifest.json"

# The built-in server transport is SSE.
# If you change manifest_remote_type to a different value,
# set manifest_remote_url explicitly to a compatible remote endpoint.
manifest_remote_type: "sse"
# manifest_remote_url: "https://logger.example.com:7777/sse"

# Health endpoint path.
health_path: "/health"
