# Ключ доступа для аутентификации запросов
access_key: "your-secret-key-here"

# Путь к файлу syslog
syslog_path: "/var/log/syslog"

# Порт сервера (по умолчанию 7777)
port: 7777

# TLS шифрование (true — HTTPS с авто-сертификатом)
tls: true

# Пути к сертификату и ключу (генерируются автоматически если не существуют)
# cert_file: "cert.pem"
# key_file: "key.pem"

# Ключ шифрования ответов (AES-256-GCM). Клиент и сервер должны знать один ключ.
# Если задан — клиент может передать encrypt: true и получить зашифрованный ответ.
encryption_key: "my-secret-encryption-key"
